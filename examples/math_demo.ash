import math

fn main() {
    print("sqrt(16):")
    print(sqrt(16.0))
    print("pow(2, 10):")
    print(pow(2.0, 10.0))
    print("abs(-42):")
    print(abs(-42))
    print("min(3, 7):")
    print(min(3, 7))
    print("max(3, 7):")
    print(max(3, 7))
    print("clamp(15, 0, 10):")
    print(clamp(15, 0, 10))
    print("floor(3.7):")
    print(floor(3.7))
    print("ceil(3.2):")
    print(ceil(3.2))
    print("sin(0.0):")
    print(sin(0.0))
}
